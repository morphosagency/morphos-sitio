---
// Intro curtain — animación CSS pura. Re-aparece en cada navegación (View Transitions
// recrea el nodo y los @keyframes vuelven a correr).
---
<div id="intro-curtain" aria-hidden="true">
  <div class="curtain-inner">
    <div class="curtain-icon" aria-hidden="true"></div>
    <div class="curtain-line"></div>
    <div class="curtain-logo">
      <span class="curtain-logo-inner">Morphos<span> Marketing</span></span>
    </div>
    <div class="curtain-sub">Marketing B2B · Industrial · México</div>
  </div>
</div>
