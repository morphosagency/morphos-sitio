---
// Enlaces internos a las landings de servicio. Sube los "incoming internal links"
// (SEO) y da navegación clara. Reutilizable en home y /servicios/.
const links = [
  { href: '/agencia-de-marketing-industrial/', title: 'Marketing industrial', desc: 'Estrategia y ejecución para empresas B2B industriales.' },
  { href: '/google-ads-monterrey/', title: 'Google Ads en Monterrey', desc: 'Captura a quien ya busca lo que vendes.' },
  { href: '/meta-ads-monterrey/', title: 'Meta Ads (Facebook e Instagram)', desc: 'Genera demanda y reconocimiento B2B.' },
  { href: '/agencia-de-seo-en-monterrey/', title: 'SEO en Monterrey', desc: 'Posicionamiento que compone con el tiempo.' },
  { href: '/agencia-de-marketing-de-contenidos/', title: 'Marketing de contenidos', desc: 'Contenido que genera demanda y autoridad.' },
  { href: '/diseno-web-monterrey/', title: 'Diseño y desarrollo web', desc: 'Sitios rápidos pensados para convertir.' },
];
---
<section class="svclinks">
  <div class="wrap">
    <div class="svclinks-head reveal">
      <div class="f-label c-green" style="margin-bottom:14px;">Servicios especializados</div>
      <h2 class="f-h2 c-navy">Explora por servicio.</h2>
    </div>
    <div class="svclinks-grid">
      {links.map((l) => (
        <a href={l.href} class="svclink reveal">
          <div class="svclink-title">{l.title}<span class="svclink-arrow">→</span></div>
          <div class="svclink-desc">{l.desc}</div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .svclinks { background: var(--off, #f5f5f3); padding: 90px 0; }
  .svclinks-head { margin-bottom: 44px; }
  .svclinks-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .svclink {
    display: block;
    background: #fff;
    border: 1px solid rgba(13, 27, 42, 0.08);
    border-radius: 14px;
    padding: 26px 24px;
    text-decoration: none;
    transition: transform 0.4s var(--ease), box-shadow 0.4s var(--ease), border-color 0.4s var(--ease);
  }
  .svclink:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 36px rgba(13, 27, 42, 0.08);
    border-color: rgba(122, 158, 126, 0.5);
  }
  .svclink-title {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700; font-size: 1.05rem;
    color: var(--navy, #0d1b2a);
    display: flex; justify-content: space-between; align-items: center; gap: 12px;
    margin-bottom: 8px; line-height: 1.25;
  }
  .svclink-arrow { color: var(--green, #7a9e7e); transition: transform 0.3s var(--ease); }
  .svclink:hover .svclink-arrow { transform: translateX(5px); }
  .svclink-desc { font-size: 0.9rem; color: rgba(13, 27, 42, 0.55); line-height: 1.5; }
  @media (max-width: 860px) { .svclinks-grid { grid-template-columns: 1fr; } }
</style>
