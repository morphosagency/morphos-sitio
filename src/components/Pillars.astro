---
// Banda de 4 pilares/diferenciadores — reutilizable en todas las landings.
// Tarjetas blancas sobre banda clara (contrasta con el hero oscuro), alto contraste.
interface Item { num: string; title: string; desc: string; }
interface Props { items: Item[]; }
const { items } = Astro.props;
---
<section class="lp-pillars">
  <div class="lp-pillars-grid">
    {items.map((it, i) => (
      <div class="lp-pillar" data-morph={String(i * 0.1)}>
        <div class="lp-pillar-num">{it.num}</div>
        <div class="lp-pillar-title">{it.title}</div>
        <div class="lp-pillar-desc">{it.desc}</div>
      </div>
    ))}
  </div>
</section>

<style>
  .lp-pillars {
    background: var(--off, #f5f5f3);
    padding: 76px 0;
    border-bottom: 1px solid rgba(13, 27, 42, 0.06);
  }
  .lp-pillars-grid {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 22px;
  }
  .lp-pillar {
    background: #fff;
    border: 1px solid rgba(13, 27, 42, 0.12);
    border-radius: 2px;
    padding: 30px 26px;
    transition: transform 0.45s var(--ease), border-color 0.45s var(--ease);
  }
  .lp-pillar:hover {
    transform: translateY(-5px);
    border-color: rgba(122, 158, 126, 0.7);
  }
  .lp-pillar-num {
    font-family: var(--serif, 'Playfair Display', serif);
    font-size: 2.1rem;
    font-weight: 700;
    color: var(--green, #7a9e7e);
    line-height: 1;
    margin-bottom: 18px;
  }
  .lp-pillar-title {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 1.08rem;
    color: var(--navy, #0d1b2a);
    margin-bottom: 9px;
    line-height: 1.25;
  }
  .lp-pillar-desc {
    font-size: 0.92rem;
    color: rgba(13, 27, 42, 0.58);
    line-height: 1.55;
  }
  @media (max-width: 900px) {
    .lp-pillars-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 500px) {
    .lp-pillars { padding: 52px 0; }
    .lp-pillars-grid { grid-template-columns: 1fr; gap: 16px; }
  }
</style>
