---
// Grid de tarjetas para secciones "Qué incluye / Qué ofrecemos / Industrias".
// Sobre fondo oscuro. Balanceado (llena el ancho), claro y premium.
interface Item { title: string; desc: string; tag?: string; }
interface Props { items: Item[]; cols?: number; }
const { items, cols = 2 } = Astro.props;
const delay = (i: number) => ` reveal-delay-${i % 3}`.replace('-0', '');
---
<div class="off-grid" style={`--cols:${cols}`}>
  {items.map((it, i) => (
    <div class={`off-card reveal${delay(i)}`}>
      {it.tag && <span class="off-tag">{it.tag}</span>}
      <h3 class="off-title">{it.title}</h3>
      <p class="off-desc">{it.desc}</p>
    </div>
  ))}
</div>

<style>
  .off-grid {
    display: grid;
    grid-template-columns: repeat(var(--cols, 2), 1fr);
    gap: 20px;
  }
  .off-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 2px;
    padding: 32px 30px;
    transition: transform 0.4s var(--ease), border-color 0.4s var(--ease), background 0.4s var(--ease);
  }
  .off-card:hover {
    transform: translateY(-4px);
    border-color: rgba(122, 158, 126, 0.5);
    background: rgba(255, 255, 255, 0.05);
  }
  .off-tag {
    display: inline-block;
    font-family: 'Montserrat', sans-serif;
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--green); margin-bottom: 14px;
  }
  .off-title {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700; font-size: 1.15rem;
    color: #fff; margin-bottom: 10px; line-height: 1.3;
  }
  .off-desc {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.93rem; line-height: 1.6;
  }
  @media (max-width: 820px) {
    .off-grid { grid-template-columns: 1fr !important; }
  }
</style>
