---
import Base from '../layouts/Base.astro';
import Pillars from '../components/Pillars.astro';
import Offerings from '../components/Offerings.astro';

const pillars = [
  { num: '01', title: 'Diseñado para convertir', desc: 'No solo bonito. Cada sección guía a tu comprador hacia un paso concreto: cotizar, contactar, agendar.' },
  { num: '02', title: 'Rápido y técnico', desc: 'Core Web Vitals en verde. Un sitio que carga lento tira tu pauta y aleja a tu comprador.' },
  { num: '03', title: 'Listo para SEO desde la base', desc: 'URLs limpias, estructura semántica y datos estructurados. Construido para posicionar, no para rehacer después.' },
  { num: '04', title: 'Con medición incluida', desc: 'GA4 y tracking de conversiones desde el día uno. Si no se mide, no se puede mejorar.' },
];

const incluye = [
  { title: 'Diseño UX/UI premium', desc: 'Diseño a la altura de tu posicionamiento, pensado en el recorrido de tu comprador industrial — no plantillas genéricas.' },
  { title: 'Desarrollo rápido', desc: 'Código limpio y optimizado para velocidad (Core Web Vitals). Un sitio veloz convierte más y mejora tu costo por lead en pauta.' },
  { title: 'SEO técnico desde la base', desc: 'URLs reales, estructura semántica, schema markup y sitemap. El sitio nace listo para posicionar, no parchado después.' },
  { title: 'Tracking y medición', desc: 'GA4, eventos de conversión y formularios medidos end-to-end. Sabes de dónde vienen tus leads desde el primer día.' },
];

const faqs = [
  {
    q: '¿Cuánto cuesta un sitio web con Morphos?',
    a: 'Depende del alcance: número de páginas, complejidad del diseño, integraciones y si incluye landings de campaña o e-commerce. No vendemos paquetes cerrados porque un sitio de 5 páginas no cuesta lo mismo que uno de 30 con integraciones. Lo que sí es constante: construimos sitios pensados para convertir y posicionar, no solo para "verse bien". En la llamada inicial revisamos lo que necesitas y te damos un número concreto, sin sorpresas.'
  },
  {
    q: '¿En qué plataforma construyen el sitio?',
    a: 'Elegimos la tecnología según tu caso, no al revés. Para sitios de marketing que necesitan velocidad y SEO solemos usar tecnologías modernas que cargan rápido y rankean bien; para clientes que necesitan administrar su contenido sin depender de nadie, plataformas más amigables. Lo importante no es la herramienta de moda, sino que el sitio cargue rápido, convierta y sea fácil de mantener. Te recomendamos lo que conviene a tu operación, con sus pros y contras claros.'
  },
  {
    q: '¿El sitio incluye SEO?',
    a: 'Incluye el SEO técnico de base: URLs limpias, estructura semántica, schema markup, sitemap, velocidad optimizada y tracking. Es decir, el sitio nace técnicamente listo para posicionar. El SEO continuo — contenido, autoridad y posicionamiento de palabras clave a lo largo del tiempo — es un trabajo aparte que podemos sumar. La diferencia: muchos sitios bonitos están rotos para SEO por dentro y hay que rehacerlos; nosotros construimos sobre cimientos correctos desde el inicio.'
  },
  {
    q: '¿Cuánto tarda en estar listo?',
    a: 'Un sitio de marketing típico toma entre 4 y 8 semanas, según el número de páginas, la rapidez con que recibamos tu contenido (textos, imágenes, accesos) y las rondas de revisión. Landing pages individuales para campaña son más rápidas. Trabajamos por etapas con entregas para que veas el avance y des feedback en el camino, no un "gran reveal" al final. Antes de lanzar verificamos que todo —diseño, velocidad, formularios y tracking— funcione correctamente.'
  }
];
---
<Base
  title='Diseño y Desarrollo Web B2B en Monterrey | Morphos'
  description='Diseño y desarrollo de páginas web para empresas B2B e industriales en Monterrey. Sitios rápidos, listos para SEO y pensados para convertir visitantes en leads — no solo para verse bien.'
  canonical='https://www.morphosagency.com/diseno-web-monterrey/'
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
  })} />

  <div class="page active" id="page-web">
    <section class="srv-hero">
      <div class="srv-hero-bg-num">W</div>
      <div class="wrap srv-hero-inner">
        <a class="page-back" href="/">← Inicio</a>
        <div class="srv-hero-content">
          <div class="f-label c-green" style="margin-bottom:20px;">Diseño Web · B2B · Monterrey</div>
          <h1 class="f-h1 c-white" style="overflow:hidden;">
            <span style="display:block; animation: lineUp 0.8s var(--ease) both;">Diseño de páginas <em class="f-serif-accent">web</em></span>
            <span style="display:block; animation: lineUp 0.8s 0.12s var(--ease) both;">en Monterrey.</span>
          </h1>
          <p class="f-body" style="color:rgba(255,255,255,0.45); margin-top:24px; max-width:540px; animation: fadeUp 0.8s 0.3s var(--ease) both;">Diseño y desarrollo web para empresas B2B e industriales. Sitios rápidos, listos para SEO y pensados para convertir visitantes en oportunidades de venta — no solo para verse bonitos.</p>
          <div style="margin-top:36px; animation: fadeUp 0.8s 0.45s var(--ease) both;">
            <a href="/agenda/" class="btn btn-primary btn-lg"><span>Agenda una llamada</span><span class="arrow">→</span></a>
          </div>
        </div>
      </div>
    </section>

    <Pillars items={pillars} />

    <section class="services" style="padding-top:100px; padding-bottom:90px;">
      <div class="wrap" style="max-width:820px;">
        <div class="f-label c-green reveal" style="margin-bottom:20px;">Por qué importa</div>
        <h2 class="f-h2 c-navy reveal" style="margin-bottom:32px;">Un sitio bonito que no<br>convierte es un folleto caro.</h2>
        <p class="f-body c-muted reveal" style="margin-bottom:24px;">La mayoría de los sitios industriales son catálogos digitales: se ven decentes, pero no guían al visitante a hacer nada. El resultado es tráfico que entra y se va sin dejar rastro. Un buen sitio B2B hace tres cosas: <strong>genera confianza</strong> en un comprador que investiga a fondo, <strong>guía a la conversión</strong> (cotizar, contactar, agendar) y <strong>se deja encontrar</strong> en buscadores.</p>
        <p class="f-body c-muted reveal reveal-delay-1" style="margin-bottom:24px;">Y la velocidad no es un lujo: un sitio que carga lento tira el presupuesto de tu pauta — pagas por el clic y el visitante se va antes de que cargue. Por eso construimos sobre cimientos técnicos correctos: rápido, semántico y medible desde el inicio.</p>
        <p class="f-body c-muted reveal reveal-delay-2">El sitio es la base de todo lo demás: tu <a href="/google-ads-monterrey/" style="color:var(--green); text-decoration:underline;">pauta</a> y tu <a href="/agencia-de-seo-en-monterrey/" style="color:var(--green); text-decoration:underline;">SEO</a> solo rinden si la página a la que llegan convierte.</p>
      </div>
    </section>

    <section class="addons-catalog-section">
      <div class="wrap">
        <div class="addons-catalog-header reveal">
          <div>
            <div class="f-label c-green" style="margin-bottom:16px;">Qué incluye</div>
            <h2 class="f-h2" style="color:var(--white);">Del diseño<br>a la conversión.</h2>
          </div>
          <p class="f-body c-muted" style="padding-top:8px;">Un sitio construido para trabajar — rápido, encontrable y medible — no solo para verse bien.</p>
        </div>
        <div class="reveal reveal-delay-1">
          <Offerings items={incluye} cols={2} />
        </div>
        <div class="reveal reveal-delay-2" style="text-align:center; margin-top:48px;">
          <a href="/metodologia/" class="btn btn-ghost"><span>Cómo se conecta con nuestra metodología 360</span><span class="arrow">→</span></a>
        </div>
      </div>
    </section>

    <section class="faq-split-section">
      <div class="wrap">
        <div class="faq-split-grid">
          <div class="faq-split-left">
            <div class="faq-highlight reveal">
              <div class="faq-highlight-label">El criterio de fondo</div>
              <div class="faq-highlight-quote">Tu sitio no es un folleto. Es tu <em>mejor vendedor</em> — si está bien construido.</div>
              <div class="faq-highlight-sub">Diseñamos para convertir y medir, sobre cimientos técnicos que rankean. No solo para verse bien.</div>
            </div>
          </div>
          <div class="faq-split-right">
            <div class="f-label c-green" style="margin-bottom:16px;">Preguntas frecuentes</div>
            <h2 class="f-h2 c-navy" style="margin-bottom:40px;">Diseño web B2B,<br>con propósito.</h2>
            <div class="faq-list">
              {faqs.map((f, i) => (
                <div class={`faq-item reveal${i % 3 === 1 ? ' reveal-delay-1' : i % 3 === 2 ? ' reveal-delay-2' : ''}`}>
                  <button class="faq-q" aria-expanded="false"><span>{f.q}</span><span class="faq-icon">+</span></button>
                  <div class="faq-a"><p>{f.a}</p></div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="cta-final">
      <div class="section-snake" aria-hidden="true" data-morph-bg></div>
      <div class="wrap cta-final-inner">
        <div class="cta-tag reveal">Siguiente paso</div>
        <h2 data-morph>¿Listo para un sitio que<br><em>trabaje</em> por ti?</h2>
        <p class="reveal reveal-delay-2">Agenda 30 minutos con Omar. Revisamos tu sitio actual, dónde está perdiendo conversiones y qué tendría más impacto — sin presentación de ventas.</p>
        <div class="reveal reveal-delay-3">
          <a href="/agenda/" class="btn btn-primary btn-lg"><span>Agenda tu llamada gratuita</span><span class="arrow">→</span></a>
          <p class="cta-note">Sesión 1 a 1 con Omar · 30 minutos · Sin compromiso</p>
        </div>
      </div>
    </section>
  </div>
</Base>
