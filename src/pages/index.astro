---
import Base from '../layouts/Base.astro';
import ServiceLinks from '../components/ServiceLinks.astro';
---
<Base title='Agencia de Marketing B2B Industrial en Monterrey | Morphos' description='Agencia de marketing B2B para empresas industriales en Monterrey y todo México. Google Ads, Meta Ads y SEO que se miden en oportunidades de venta, no en likes. Sin microgestión.' canonical='https://www.morphosagency.com/'>
  <div class="page active" id="page-home">

    <!-- ════ HERO ════ -->
    <section class="hero" id="main-content">
      <!--
        VIDEO HERO — Para activar, descomenta el bloque <video> y comenta el ::before grid en CSS.
        El video debe ser: MP4 + WebM, mínimo 1920x1080, sin audio, loop, autoplay.
        Usar un poster (primera frame) para evitar flash blanco al cargar.

      <video class="hero-video" autoplay muted loop playsinline poster="video-poster.jpg">
        <source src="hero-video.webm" type="video/webm">
        <source src="hero-video.mp4" type="video/mp4">
      </video>
      -->

      <div class="hero-body">
        <div class="hero-content">
          <div class="hero-tag">
            <div class="hero-tag-dot"></div>
            <h1>Agencia de Marketing B2B Industrial en Monterrey</h1>
          </div>

          <p class="hero-headline" role="presentation">
            <span class="line-wrap"><span class="line">Marketing que</span></span>
            <span class="line-wrap"><span class="line line-serif">toma forma.</span></span>
          </p>

          <p class="hero-sub">Somos la agencia de marketing B2B para empresas industriales en Monterrey y todo México. Estrategia y ejecución que se mide en pipeline, no en likes. Sin microgestión: tú decides el rumbo, nosotros entregamos.</p>

          <div class="hero-ctas">
            <a href="/agenda/" class="btn btn-primary">
              <span>Agenda tu llamada</span>
              <span class="arrow">→</span>
            </a>
            <a href="/metodologia/" class="btn btn-ghost">
              <span>Ver resultados</span>
            </a>
          </div>

          <p class="hero-note">Sesión 1 a 1 · 30 minutos · Sin compromiso</p>
        </div>
      </div>

      <div class="scroll-hint">
        <span>Scroll</span>
        <div class="scroll-line"></div>
      </div>
    </section>

    <!-- ════ MARQUEE ════ -->
    <div class="marquee">
      <div class="marquee-track">
        <div class="marquee-item"><span>Google Ads B2B</span><span class="dot"></span></div>
        <div class="marquee-item"><span>Meta Ads</span><span class="dot"></span></div>
        <div class="marquee-item"><span>SEO Industrial</span><span class="dot"></span></div>
        <div class="marquee-item"><span>Estrategia 360</span><span class="dot"></span></div>
        <div class="marquee-item"><span>Generación de Leads</span><span class="dot"></span></div>
        <div class="marquee-item"><span>Marketing B2B</span><span class="dot"></span></div>
        <div class="marquee-item"><span>Manufactura</span><span class="dot"></span></div>
        <div class="marquee-item"><span>Construcción</span><span class="dot"></span></div>
        <div class="marquee-item"><span>Servicios Industriales</span><span class="dot"></span></div>
        <div class="marquee-item"><span>Google Ads B2B</span><span class="dot"></span></div>
        <div class="marquee-item"><span>Meta Ads</span><span class="dot"></span></div>
        <div class="marquee-item"><span>SEO Industrial</span><span class="dot"></span></div>
        <div class="marquee-item"><span>Estrategia 360</span><span class="dot"></span></div>
        <div class="marquee-item"><span>Generación de Leads</span><span class="dot"></span></div>
        <div class="marquee-item"><span>Marketing B2B</span><span class="dot"></span></div>
        <div class="marquee-item"><span>Manufactura</span><span class="dot"></span></div>
        <div class="marquee-item"><span>Construcción</span><span class="dot"></span></div>
        <div class="marquee-item"><span>Servicios Industriales</span><span class="dot"></span></div>
      </div>
    </div>

    <!-- ════ STATEMENT ════ -->
    <section class="statement">
      <div class="wrap">
        <div class="statement-inner">
          <p class="statement-headline" data-morph>La mayoría de las agencias ejecutan sin entender el negocio de su cliente. Morphos no.</p>
          <div class="statement-body reveal reveal-delay-2">Antes de proponer una sola campaña, auditamos tu situación, entendemos tu ciclo de venta, y construimos una estrategia que conecta el marketing con resultados reales de negocio — no con métricas de vanidad. Cada peso invertido tiene una justificación.</div>
        </div>
      </div>
    </section>

    <!-- ════ MANIFIESTO ════ -->
    <section class="manifesto">
      <div class="wrap">
        <div class="manifesto-inner">
          <div class="manifesto-label f-label c-green reveal">El estándar Morphos</div>
          <h2 class="f-display manifesto-line" data-morph>No reportamos likes. Construimos pipeline que se convierte en <em>ventas.</em></h2>
          <p class="manifesto-sub reveal">Marketing B2B industrial medido en oportunidades de venta reales — cada peso invertido, justificado.</p>
        </div>
      </div>
    </section>

    <!-- ════ DIFERENCIADORES ════ -->
    <section class="diff">
      <div class="wrap">
        <div class="diff-header">
          <div>
            <div class="f-label c-green reveal" style="margin-bottom:16px;">El problema</div>
            <h2 class="f-h2 c-navy" data-morph>Por qué el marketing<br>industrial falla.</h2>
          </div>
          <div class="reveal reveal-delay-2">
            <p class="f-body c-muted">Tres razones por las que la mayoría de las empresas B2B no obtienen resultados con el marketing — y cómo Morphos los resuelve.</p>
            <div style="height:24px;"></div>
            <a href="/agenda/" class="btn btn-dark">
              <span>Hablemos de tu caso</span>
              <span class="arrow">→</span>
            </a>
          </div>
        </div>
        <div class="diff-items">
          <div class="diff-item" data-morph>
            <div class="diff-item-num">01</div>
            <h3>Agencias que ejecutan sin estrategia</h3>
            <p>Crean anuncios sin entender tu ciclo de venta ni cuánto vale realmente un cliente nuevo. El resultado es presupuesto quemado y leads que no califican.</p>
          </div>
          <div class="diff-item" data-morph="0.12">
            <div class="diff-item-num">02</div>
            <h3>Métricas de vanidad en lugar de negocio</h3>
            <p>Reportes llenos de impresiones y clics que no responden la pregunta real: ¿cuánto negocio generó el marketing este mes? Morphos reporta en pesos y leads.</p>
          </div>
          <div class="diff-item" data-morph="0.24">
            <div class="diff-item-num">03</div>
            <h3>Sin entender el sector industrial</h3>
            <p>Vender maquinaria, servicios contra incendios o materiales de construcción no es lo mismo que vender ropa. Los ciclos, los compradores, y el mensaje son distintos.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ════ PROCESO ════ -->
    <section class="process">
      <div class="wrap process-inner">
        <div class="process-header">
          <div class="f-label c-green reveal" style="margin-bottom:16px;">Cómo trabajamos</div>
          <h2 class="f-h2 c-white" data-morph style="max-width:560px;">Diagnóstico primero.<br>Estrategia después.<br>Resultados siempre.</h2>
        </div>
        <div class="process-steps">
          <div class="pstep reveal" data-step="1">
            <div class="pstep-n">01</div>
            <div class="pstep-label">Diagnóstico</div>
            <h3>Entendemos tu negocio antes de proponer nada.</h3>
            <p>Auditamos tu presencia digital, analizamos tu competencia, y entendemos tu ciclo de venta. Sin diagnóstico no hay estrategia — solo adivinar.</p>
            <div class="pstep-hint">Ver qué auditamos ↗</div>
          </div>
          <div class="pstep reveal reveal-delay-1" data-step="2">
            <div class="pstep-n">02</div>
            <div class="pstep-label">Estrategia</div>
            <h3>Un plan que conecta marketing con resultados de negocio.</h3>
            <p>Canales, presupuesto, objetivos y KPIs que realmente importan. Pipeline generado, no impresiones. Todo documentado y aprobado antes de ejecutar.</p>
            <div class="pstep-hint">Ver cómo construimos el plan ↗</div>
          </div>
          <div class="pstep reveal reveal-delay-2" data-step="3">
            <div class="pstep-n">03</div>
            <div class="pstep-label">Ejecución</div>
            <h3>Ejecutamos, medimos y optimizamos semana a semana.</h3>
            <p>Campañas, SEO, creativos — todo coordinado. Y si algo no funciona, lo ajustamos antes de que cueste demasiado. Sin esperar al reporte mensual.</p>
            <div class="pstep-hint">Ver cómo ejecutamos ↗</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════ SERVICIOS (preview) ════ -->
    <section class="services">
      <div class="wrap">
        <div class="services-header">
          <div>
            <div class="f-label c-green reveal" style="margin-bottom:16px;">Servicios</div>
            <h2 class="f-h2 c-navy" data-morph>El paquete correcto<br>para cada etapa.</h2>
          </div>
          <div class="reveal reveal-delay-1">
            <p class="f-body c-muted" style="margin-bottom:24px;">Fee mensual sin contratos de largo plazo. Pauta siempre adicional y separada — así sabes exactamente qué va a los medios y qué al servicio. <strong>Los montos son un punto de partida: cada propuesta se cotiza a la medida de tu objetivo, mercado y alcance.</strong></p>
            <div class="services-note">Contratos mes a mes · Aviso 30 días · Sin permanencia forzada · Propuesta personalizada</div>
          </div>
        </div>
        <div class="packages">
          <a href="/agenda/" class="pkg" data-morph>
            <div class="pkg-badge">Para empresas que inician</div>
            <div class="pkg-name">Esencial</div>
            <div class="pkg-price">Desde <strong>$12,000</strong> MXN/mes</div>
            <div class="pkg-div"></div>
            <div class="pkg-desc">Cimenta las bases correctas antes de escalar: tracking, campañas y landing pages que convierten.</div>
            <ul class="pkg-list">
              <li>Google Ads + Meta Ads</li>
              <li>Tracking completo (GA4 + Pixel + CAPI)</li>
              <li>Landing pages optimizadas</li>
              <li>Reporte mensual de resultados</li>
            </ul>
            <div class="pkg-cta">Ver paquete <span class="arrow">→</span></div>
          </a>
          <a href="/agenda/" class="pkg pkg--featured" data-morph="0.12">
            <div class="pkg-badge">El más elegido</div>
            <div class="pkg-name">Crecimiento</div>
            <div class="pkg-price">Desde <strong>$18,000</strong> MXN/mes</div>
            <div class="pkg-div"></div>
            <div class="pkg-desc">Para empresas con base digital que quieren escalar activamente con estrategia profunda.</div>
            <ul class="pkg-list">
              <li>Todo lo de Esencial, más:</li>
              <li>Estrategia de contenido y SEO</li>
              <li>Dirección creativa para ads</li>
              <li>Optimización semanal de campañas</li>
              <li>QBR trimestral estratégico</li>
            </ul>
            <div class="pkg-cta">Agenda tu llamada <span class="arrow">→</span></div>
          </a>
          <a href="/agenda/" class="pkg" data-morph="0.24">
            <div class="pkg-badge">Para empresas ambiciosas</div>
            <div class="pkg-name">Escala</div>
            <div class="pkg-price">Desde <strong>$30,000</strong> MXN/mes</div>
            <div class="pkg-div"></div>
            <div class="pkg-desc">Un socio estratégico de alto nivel con visión de CMO fraccionario dedicado a tu negocio.</div>
            <ul class="pkg-list">
              <li>Todo lo de Crecimiento, más:</li>
              <li>CMO fraccionario dedicado</li>
              <li>Estrategia multicanal completa</li>
              <li>Dashboard de resultados en tiempo real</li>
              <li>Revisiones quincenales de estrategia</li>
            </ul>
            <div class="pkg-cta">Ver paquete <span class="arrow">→</span></div>
          </a>
        </div>
        <div class="services-more reveal">
          <a class="services-more-link" href="/servicios/">
            Ver add-ons, cómo arrancamos y preguntas frecuentes <span>→</span>
          </a>
        </div>
      </div>
    </section>

    <ServiceLinks />

    <!-- ════ MÉTODO (teaser) ════ -->
    <section class="case">
      <div class="wrap case-inner">
        <div class="case-header">
          <div>
            <div class="case-tag reveal">Cómo trabajamos · Marketing B2B industrial</div>
            <h2 data-morph>De cero presencia digital<br>a un canal de leads predecible.</h2>
          </div>
          <div class="case-header-right reveal reveal-delay-1">
            <p>Un canal de demanda B2B industrial no se construye con un pico de un mes — se construye por etapas, con tracking limpio desde el día 1 y decisiones basadas en datos. Así es el camino.</p>
            <a href="/metodologia/" class="btn btn-ghost">
              <span>Ver cómo lo construimos</span>
              <span class="arrow">→</span>
            </a>
          </div>
        </div>
        <div class="case-numbers reveal">
          <div class="case-num">
            <div class="case-num-val"><span class="accent">0</span> → 120<span class="accent">+</span></div>
            <div class="case-num-label">
              <strong>Leads mensuales que rinde un canal bien construido</strong>
              No de la noche a la mañana: crecimiento sostenido a lo largo de ~24 meses.
            </div>
          </div>
          <div class="case-number-div"></div>
          <div class="case-num">
            <div class="case-num-val"><span class="accent">1</span> sistema</div>
            <div class="case-num-label">
              <strong>Google + Meta + SEO + medición, integrados</strong>
              No canales sueltos: una estrategia 360 que se mide en oportunidades de venta.
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════ NOSOTROS (teaser) ════ -->
    <section class="about">
      <div class="wrap">
        <div class="about-grid">
          <div class="about-photo reveal">
            <div class="monogram-frame">
              <div class="monogram-snake" aria-hidden="true"></div>
              <span class="monogram-os" aria-hidden="true">OS</span>
            </div>
            <div class="photo-frame-tag">
              <span>Director · Morphos</span>
            </div>
          </div>
          <div class="about-content reveal reveal-delay-2">
            <div class="about-tag">Quién está detrás</div>
            <h2>Omar Sandoval.<br>Marketing B2B con <em>criterio propio.</em></h2>
            <p class="body">Llevo más de 5 años ejecutando marketing para empresas B2B en México — desde PyMEs industriales hasta corporativos con operaciones en varios estados. He gestionado cuentas de Google Ads y Meta desde $5,000 hasta $500,000 USD al mes.</p>
            <p class="body">Fundé Morphos porque el mercado industrial en México merecía una agencia que realmente entienda sus ciclos de venta, sus compradores, y la diferencia entre un lead que califica y uno que no.</p>
            <div style="margin-top:32px;">
              <a class="services-more-link" href="/nosotros/">
                Conocer más sobre Morphos <span>→</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════ CTA FINAL ════ -->
    <section class="cta-final">
      <div class="section-snake" aria-hidden="true" data-morph-bg></div>
      <div class="wrap cta-final-inner">
        <div class="cta-tag reveal">Próximo paso</div>
        <h2 data-morph>¿Listo para que el marketing<br>de tu empresa <em>funcione?</em></h2>
        <p class="reveal reveal-delay-2">Una llamada de 30 minutos. Sin presentación de ventas. Solo las preguntas correctas y una respuesta honesta.</p>
        <div class="reveal reveal-delay-3">
          <a href="/agenda/" class="btn btn-primary btn-lg">
            <span>Agenda tu llamada gratuita</span>
            <span class="arrow">→</span>
          </a>
          <p class="cta-note">Sesión 1 a 1 con Omar · 30 minutos · Sin compromiso</p>
        </div>
      </div>
    </section>

  </div>
</Base>
