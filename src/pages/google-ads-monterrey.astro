---
import Base from '../layouts/Base.astro';
import Pillars from '../components/Pillars.astro';
import Offerings from '../components/Offerings.astro';

const pillars = [
  { num: '01', title: 'Captura demanda existente', desc: 'Apareces frente a quien ya busca tu producto o servicio — el lead más cercano a la compra que hay.' },
  { num: '02', title: 'Optimizado a leads, no a clics', desc: 'No perseguimos clics baratos. Configuramos las campañas para maximizar oportunidades de venta reales.' },
  { num: '03', title: 'Tracking verificado antes de lanzar', desc: 'Ninguna campaña activa sin confirmar que las conversiones se registran. Datos sucios = decisiones sucias.' },
  { num: '04', title: 'Sin microgestión, mes a mes', desc: 'Firmas y ejecutamos con autonomía. Reportamos pipeline, no actividad. Sin contratos que aten.' },
];

const incluye = [
  { title: 'Estructura por intención', desc: 'Campañas organizadas por la intención real de búsqueda de tu comprador, con palabras clave y concordancias que filtran lo que no califica.' },
  { title: 'Tracking y conversiones', desc: 'GA4, etiquetas de conversión y página de gracias verificadas end-to-end antes de lanzar. Medimos lo que importa: leads, no visitas.' },
  { title: 'Optimización continua', desc: 'Ajuste semanal de pujas, palabras clave, anuncios y negativos. Cortamos lo que no funciona antes de que cueste de más.' },
  { title: 'Reportes con narrativa', desc: 'Cada mes: qué pasó, por qué, qué aprendimos y qué sigue. Orientado a negocio — costo por lead y pipeline, no impresiones.' },
];

const faqs = [
  {
    q: '¿Cuánto cuesta Google Ads con Morphos?',
    a: 'Hay dos costos separados: el fee de Morphos (gestión, estrategia y optimización) y el presupuesto de pauta, que va directo a Google desde tu cuenta. Los mantenemos separados a propósito: así tienes claridad total sobre qué dinero va a los medios y qué al servicio. El fee depende del alcance del trabajo; el presupuesto de pauta lo defines tú según tus objetivos. En la llamada inicial te damos números concretos para tu caso, sin paquetes genéricos.'
  },
  {
    q: '¿Cuánto presupuesto de pauta necesito?',
    a: 'Para Google Ads B2B en México recomendamos un mínimo de $15,000–$20,000 MXN/mes de pauta para tener datos suficientes y que el algoritmo aprenda a buen ritmo. Con menos, las campañas tardan más en madurar y los resultados son inestables. El monto exacto depende de tu industria, la competencia por tus palabras clave y tus objetivos de leads. En la llamada inicial te decimos cuánto necesitas según tu caso real — sin inflar el número.'
  },
  {
    q: '¿Qué conviene, Google Ads o SEO?',
    a: 'Resuelven cosas distintas. Google Ads trae leads rápido — en semanas — pero dejas de aparecer en cuanto pausas la inversión. El SEO tarda más en madurar (6-12 meses) pero construye un activo que sigue trayendo clientes sin pagar por clic. En B2B industrial la jugada ideal suele ser combinarlos: Google Ads para capturar demanda inmediata mientras el SEO compone en el fondo y reduce tu dependencia de la pauta con el tiempo. En la llamada te decimos cuál priorizar según tu urgencia y presupuesto.'
  },
  {
    q: '¿Cuánto tarda Google Ads en traer leads?',
    a: 'Es el canal más rápido: con el tracking bien configurado, los primeros leads suelen aparecer en las primeras 2 a 3 semanas. Las primeras semanas son de aprendizaje y ajuste — vamos afinando palabras clave, anuncios y pujas con datos reales. A partir del segundo mes, con la campaña ya optimizada, el costo por lead se estabiliza y se vuelve predecible. Por el ciclo de venta largo del B2B industrial, el lead llega rápido pero el cierre toma su tiempo; por eso medimos todo el embudo, no solo el primer contacto.'
  }
];
---
<Base
  title='Agencia de Google Ads B2B en Monterrey | Morphos'
  description='Agencia de Google Ads para empresas B2B e industriales en Monterrey y México. Campañas optimizadas a leads calificados, no a clics, con tracking verificado. Sin microgestión.'
  canonical='https://www.morphosagency.com/google-ads-monterrey/'
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
  })} />

  <div class="page active" id="page-google">
    <section class="srv-hero">
      <div class="srv-hero-bg-num">G</div>
      <div class="wrap srv-hero-inner">
        <a class="page-back" href="/">← Inicio</a>
        <div class="srv-hero-content">
          <div class="f-label c-green" style="margin-bottom:20px;">Google Ads · B2B · Monterrey</div>
          <h1 class="f-h1 c-white" style="overflow:hidden;">
            <span style="display:block; animation: lineUp 0.8s var(--ease) both;">Agencia de Google Ads</span>
            <span style="display:block; animation: lineUp 0.8s 0.12s var(--ease) both;">en Monterrey.</span>
          </h1>
          <p class="f-body" style="color:rgba(255,255,255,0.45); margin-top:24px; max-width:540px; animation: fadeUp 0.8s 0.3s var(--ease) both;">Campañas de Google Ads para empresas B2B e industriales. Capturamos a quien ya busca lo que vendes y optimizamos a oportunidades de venta reales — no a clics baratos. El canal más rápido para traer leads.</p>
          <div style="margin-top:36px; animation: fadeUp 0.8s 0.45s var(--ease) both;">
            <a href="/agenda/" class="btn btn-primary btn-lg"><span>Agenda una llamada</span><span class="arrow">→</span></a>
          </div>
        </div>
      </div>
    </section>

    <Pillars items={pillars} />

    <section class="services" style="padding-top:100px; padding-bottom:90px;">
      <div class="wrap" style="max-width:820px;">
        <div class="f-label c-green reveal" style="margin-bottom:20px;">Por qué importa</div>
        <h2 class="f-h2 c-navy reveal" style="margin-bottom:32px;">El lead más caliente<br>es el que ya te busca.</h2>
        <p class="f-body c-muted reveal" style="margin-bottom:24px;">Cuando alguien busca en Google "proveedor de [tu producto industrial]", está más cerca de comprar que cualquier otra audiencia. Google Ads te pone justo frente a esa persona, en el momento exacto de la intención. Por eso es <strong>el canal más rápido</strong> para generar leads — y el mejor para validar demanda antes de invertir en canales de más largo plazo.</p>
        <p class="f-body c-muted reveal reveal-delay-1" style="margin-bottom:24px;">El problema: la mayoría de las campañas optimizan a clics baratos y palabras genéricas que traen tráfico que no califica. Nosotros estructuramos por intención real, filtramos con concordancias y negativos, y optimizamos a <strong>leads que tu equipo comercial pueda cerrar</strong> — no a métricas que se ven bien en un reporte.</p>
        <p class="f-body c-muted reveal reveal-delay-2">Y nunca lanzamos a ciegas: el <a href="/agencia-de-seo-en-monterrey/" style="color:var(--green); text-decoration:underline;">tracking</a> se verifica end-to-end antes de gastar el primer peso. Sin medición correcta, optimizar es adivinar.</p>
      </div>
    </section>

    <section class="addons-catalog-section">
      <div class="wrap">
        <div class="addons-catalog-header reveal">
          <div>
            <div class="f-label c-green" style="margin-bottom:16px;">Qué incluye</div>
            <h2 class="f-h2" style="color:var(--white);">De la intención<br>al pipeline.</h2>
          </div>
          <p class="f-body c-muted" style="padding-top:8px;">Campañas estructuradas, medidas y optimizadas — no "poner anuncios" y esperar.</p>
        </div>
        <div class="reveal reveal-delay-1">
          <Offerings items={incluye} cols={2} />
        </div>
        <div class="reveal reveal-delay-2" style="text-align:center; margin-top:48px;">
          <a href="/metodologia/" class="btn btn-ghost"><span>Cómo se conecta con nuestra metodología 360</span><span class="arrow">→</span></a>
        </div>
      </div>
    </section>

    <section class="faq-split-section">
      <div class="wrap">
        <div class="faq-split-grid">
          <div class="faq-split-left">
            <div class="faq-highlight reveal">
              <div class="faq-highlight-label">El criterio de fondo</div>
              <div class="faq-highlight-quote">Mil clics baratos no valen un solo lead que tu <em>equipo pueda cerrar.</em></div>
              <div class="faq-highlight-sub">Optimizamos a oportunidades de venta, con el tracking verificado antes de gastar el primer peso.</div>
            </div>
          </div>
          <div class="faq-split-right">
            <div class="f-label c-green" style="margin-bottom:16px;">Preguntas frecuentes</div>
            <h2 class="f-h2 c-navy" style="margin-bottom:40px;">Google Ads B2B,<br>sin desperdicio.</h2>
            <div class="faq-list">
              {faqs.map((f, i) => (
                <div class={`faq-item reveal${i % 3 === 1 ? ' reveal-delay-1' : i % 3 === 2 ? ' reveal-delay-2' : ''}`}>
                  <button class="faq-q" aria-expanded="false"><span>{f.q}</span><span class="faq-icon">+</span></button>
                  <div class="faq-a"><p>{f.a}</p></div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="cta-final">
      <div class="wrap cta-final-inner">
        <div class="cta-tag reveal">Siguiente paso</div>
        <h2 class="reveal reveal-delay-1">¿Listo para capturar a quien<br>ya está <em>buscándote?</em></h2>
        <p class="reveal reveal-delay-2">Agenda 30 minutos con Omar. Revisamos tu situación, el presupuesto que tiene sentido y si Google Ads es el canal correcto para tu etapa — sin presentación de ventas.</p>
        <div class="reveal reveal-delay-3">
          <a href="/agenda/" class="btn btn-primary btn-lg"><span>Agenda tu llamada gratuita</span><span class="arrow">→</span></a>
          <p class="cta-note">Sesión 1 a 1 con Omar · 30 minutos · Sin compromiso</p>
        </div>
      </div>
    </section>
  </div>
</Base>
