---
import Base from '../layouts/Base.astro';
import Pillars from '../components/Pillars.astro';
import Offerings from '../components/Offerings.astro';

const pillars = [
  { num: '01', title: 'Demanda donde aún no te buscan', desc: 'Meta llega a tu comprador antes de que necesite cotizar. Construyes reconocimiento mientras tu competencia espera la búsqueda.' },
  { num: '02', title: 'Segmentación B2B real', desc: 'Audiencias por industria, puesto e intención — y retargeting a quien ya visitó. No disparamos a ciegas.' },
  { num: '03', title: 'Tracking que no miente', desc: 'Pixel + Conversions API bien configurados. Sin esto, Meta optimiza con datos a medias y el costo por lead sube.' },
  { num: '04', title: 'Creativo que habla industrial', desc: 'Anuncios con el lenguaje de tu comprador técnico — no plantillas genéricas de e-commerce.' },
];

const incluye = [
  { title: 'Estrategia y audiencias', desc: 'Definición de audiencias por industria y puesto, estructura de campañas y embudo (frío, retargeting) atado a tu objetivo de leads.' },
  { title: 'Creativos y copy', desc: 'Anuncios para Facebook e Instagram que hablan el idioma de tu comprador industrial: imagen, video y texto que convierten, no que decoran.' },
  { title: 'Tracking Pixel + CAPI', desc: 'Meta Pixel y Conversions API verificados antes de lanzar. El algoritmo aprende con datos completos = menor costo por lead.' },
  { title: 'Optimización y reportes', desc: 'Revisión semanal de campañas y reporte mensual con narrativa: qué funcionó, qué ajustamos y qué sigue. Medido en leads.' },
];

const faqs = [
  {
    q: '¿Meta Ads sirve para empresas B2B industriales?',
    a: 'Sí, aunque su rol es distinto al de Google Ads. En Google capturas a quien ya busca tu producto; en Meta (Facebook e Instagram) generas demanda y reconocimiento en quien todavía no te busca, y haces retargeting a quien ya visitó tu sitio. Para B2B industrial funciona muy bien para construir marca, mantenerte presente durante ciclos de venta largos y recuperar a prospectos que no convirtieron a la primera. El comprador industrial sí usa Facebook e Instagram — solo que no compra ahí de inmediato. La clave es segmentar bien (por industria, puesto e intención) y medir en leads, no en likes.'
  },
  {
    q: '¿Cuánto presupuesto de pauta necesito en Meta?',
    a: 'Depende de tu mercado y objetivos, pero para B2B en México recomendamos un mínimo de $10,000–$15,000 MXN/mes de pauta para que el algoritmo tenga suficientes datos para optimizar. La pauta va directo a Meta desde tu cuenta y siempre es adicional al fee de Morphos — así tienes claridad total sobre qué dinero va a los medios y qué al servicio. En la llamada inicial te decimos exactamente cuánto necesitas según tu caso.'
  },
  {
    q: '¿Qué incluye el servicio de Meta Ads?',
    a: 'Cubrimos la campaña completa: estrategia y definición de audiencias, creativos y copy para Facebook e Instagram, configuración y verificación de tracking (Pixel + Conversions API), lanzamiento, optimización semanal y reporte mensual con narrativa. No activamos una sola campaña sin confirmar que las conversiones se registran correctamente — medir bien es lo primero. Todo conectado a tu estrategia general de marketing, no como un canal aislado.'
  },
  {
    q: '¿Conviene Facebook, Instagram o ambos?',
    a: 'En la práctica se trabajan juntos: Meta distribuye los anuncios entre Facebook, Instagram y sus redes según dónde esté tu audiencia y dónde rinda mejor cada peso. No es una decisión de "uno u otro" — es dejar que los datos asignen el presupuesto al lugar de mejor retorno. Lo que sí ajustamos es el formato y el mensaje según la plataforma. Para B2B industrial, Facebook suele pesar más por la edad y perfil del comprador, pero Instagram aporta en reconocimiento de marca.'
  }
];
---
<Base
  title='Agencia de Meta Ads · Facebook e Instagram Ads B2B en Monterrey | Morphos'
  description='Agencia de Meta Ads (Facebook e Instagram) para empresas B2B e industriales en Monterrey y México. Campañas que generan demanda y leads calificados, con tracking Pixel + CAPI. Sin microgestión.'
  canonical='https://www.morphosagency.com/meta-ads-monterrey/'
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
  })} />

  <div class="page active" id="page-meta">
    <section class="srv-hero">
      <div class="srv-hero-bg-num">M</div>
      <div class="wrap srv-hero-inner">
        <a class="page-back" href="/">← Inicio</a>
        <div class="srv-hero-content">
          <div class="f-label c-green" style="margin-bottom:20px;">Meta Ads · Facebook e Instagram · B2B</div>
          <h1 class="f-h1 c-white" style="overflow:hidden;">
            <span style="display:block; animation: lineUp 0.8s var(--ease) both;">Agencia de Meta Ads</span>
            <span style="display:block; animation: lineUp 0.8s 0.12s var(--ease) both;">en Monterrey.</span>
          </h1>
          <p class="f-body" style="color:rgba(255,255,255,0.45); margin-top:24px; max-width:540px; animation: fadeUp 0.8s 0.3s var(--ease) both;">Campañas de Facebook e Instagram Ads para empresas B2B e industriales. Generamos demanda y reconocimiento donde tu comprador aún no te busca — con tracking que no miente y medido en leads, no en likes.</p>
          <div style="margin-top:36px; animation: fadeUp 0.8s 0.45s var(--ease) both;">
            <a href="/agenda/" class="btn btn-primary btn-lg"><span>Agenda una llamada</span><span class="arrow">→</span></a>
          </div>
        </div>
      </div>
    </section>

    <Pillars items={pillars} />

    <section class="services" style="padding-top:100px; padding-bottom:90px;">
      <div class="wrap" style="max-width:820px;">
        <div class="f-label c-green reveal" style="margin-bottom:20px;">Por qué importa</div>
        <h2 class="f-h2 c-navy reveal" style="margin-bottom:32px;">Meta no cierra la venta.<br>Abre la puerta.</h2>
        <p class="f-body c-muted reveal" style="margin-bottom:24px;">En B2B industrial, casi nadie compra maquinaria o un servicio de ingeniería desde un anuncio de Facebook. Pero sí descubre proveedores, reconoce marcas y recuerda quién le habló con criterio cuando llega el momento de cotizar. Ese es el trabajo de Meta Ads: <strong>generar demanda y mantenerte presente</strong> durante el ciclo de venta largo, y recuperar con retargeting a quien ya mostró interés.</p>
        <p class="f-body c-muted reveal reveal-delay-1" style="margin-bottom:24px;">La mayoría de las agencias trata Meta para B2B como si vendiera al consumidor: alcance masivo y métricas de vanidad. Nosotros segmentamos por industria, puesto e intención, y medimos en <strong>leads calificados</strong> — no en likes ni alcance.</p>
        <p class="f-body c-muted reveal reveal-delay-2">Funciona mejor combinado: <a href="/google-ads-monterrey/" style="color:var(--green); text-decoration:underline;">Google Ads</a> captura la demanda inmediata, Meta construye la que viene. Juntos, dentro de la misma metodología.</p>
      </div>
    </section>

    <section class="addons-catalog-section">
      <div class="wrap">
        <div class="addons-catalog-header reveal">
          <div>
            <div class="f-label c-green" style="margin-bottom:16px;">Qué incluye</div>
            <h2 class="f-h2" style="color:var(--white);">De la audiencia<br>al reporte.</h2>
          </div>
          <p class="f-body c-muted" style="padding-top:8px;">Una campaña completa, medida y conectada a tu generación de demanda — no anuncios sueltos.</p>
        </div>
        <div class="reveal reveal-delay-1">
          <Offerings items={incluye} cols={2} />
        </div>
        <div class="reveal reveal-delay-2" style="text-align:center; margin-top:48px;">
          <a href="/metodologia/" class="btn btn-ghost"><span>Cómo se conecta con nuestra metodología 360</span><span class="arrow">→</span></a>
        </div>
      </div>
    </section>

    <section class="faq-split-section">
      <div class="wrap">
        <div class="faq-split-grid">
          <div class="faq-split-left">
            <div class="faq-highlight reveal">
              <div class="faq-highlight-label">El criterio de fondo</div>
              <div class="faq-highlight-quote">Un anuncio con muchos likes y cero leads es un <em>gasto</em>, no una campaña.</div>
              <div class="faq-highlight-sub">Optimizamos a oportunidades de venta reales, con el tracking configurado correctamente desde el día uno.</div>
            </div>
          </div>
          <div class="faq-split-right">
            <div class="f-label c-green" style="margin-bottom:16px;">Preguntas frecuentes</div>
            <h2 class="f-h2 c-navy" style="margin-bottom:40px;">Meta Ads B2B,<br>sin vanidad.</h2>
            <div class="faq-list">
              {faqs.map((f, i) => (
                <div class={`faq-item reveal${i % 3 === 1 ? ' reveal-delay-1' : i % 3 === 2 ? ' reveal-delay-2' : ''}`}>
                  <button class="faq-q" aria-expanded="false"><span>{f.q}</span><span class="faq-icon">+</span></button>
                  <div class="faq-a"><p>{f.a}</p></div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="cta-final">
      <div class="wrap cta-final-inner">
        <div class="cta-tag reveal">Siguiente paso</div>
        <h2 class="reveal reveal-delay-1">¿Listo para llegar a tu<br>comprador <em>antes</em> que tu competencia?</h2>
        <p class="reveal reveal-delay-2">Agenda 30 minutos con Omar. Revisamos si Meta tiene sentido para tu etapa y cómo encaja con tus otros canales — sin presentación de ventas.</p>
        <div class="reveal reveal-delay-3">
          <a href="/agenda/" class="btn btn-primary btn-lg"><span>Agenda tu llamada gratuita</span><span class="arrow">→</span></a>
          <p class="cta-note">Sesión 1 a 1 con Omar · 30 minutos · Sin compromiso</p>
        </div>
      </div>
    </section>
  </div>
</Base>
