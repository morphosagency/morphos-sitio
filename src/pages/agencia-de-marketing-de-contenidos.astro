---
import Base from '../layouts/Base.astro';
import Pillars from '../components/Pillars.astro';
import Offerings from '../components/Offerings.astro';

const ofrecemos = [
  { title: 'Estrategia y plan editorial', desc: 'Definimos temas, formatos y calendario atados a tu comprador y a tus objetivos. Sabes qué se publica, cuándo y por qué — nada de improvisar.' },
  { title: 'Artículos y recursos SEO', desc: 'Producimos blog optimizado, guías técnicas, casos de éxito y material descargable que posiciona tu sitio en buscadores y demuestra tu expertise.' },
  { title: 'LinkedIn y email nurturing', desc: 'Adaptamos cada pieza a LinkedIn y a secuencias de correo para llegar a tu comprador donde está y mantener el contacto en ciclos largos.' },
  { title: 'Reportes de resultados', desc: 'Qué contenido trajo tráfico y leads, qué temas mueven la aguja. Decisiones basadas en datos de negocio, no en corazonadas.' },
];

const pillars = [
  { num: '01', title: 'Contenido que vende, no que entretiene', desc: 'Cada pieza tiene un trabajo: atraer, educar o convertir a tu comprador. Nada de contenido bonito sin propósito comercial.' },
  { num: '02', title: 'Autoridad técnica B2B', desc: 'Hablamos el idioma de tu comprador industrial. Contenido con criterio técnico que genera confianza antes del primer contacto.' },
  { num: '03', title: 'Una pieza, varios canales', desc: 'Un buen contenido se reusa: blog, SEO, LinkedIn y nurturing por correo. Máximo alcance por cada esfuerzo de producción.' },
  { num: '04', title: 'Medido en leads y autoridad', desc: 'No reportamos views ni "me gusta". Medimos tráfico calificado, leads y posicionamiento — el contenido como activo, no como gasto.' },
];

const faqs = [
  {
    q: '¿Qué hace una agencia de marketing de contenidos?',
    a: 'Una agencia de marketing de contenidos crea y distribuye contenido con un objetivo comercial: atraer a tu comprador ideal, educarlo durante su proceso de decisión y convertirlo en lead. En B2B esto incluye artículos de blog optimizados para SEO, guías y casos que demuestran tu expertise, contenido para LinkedIn y secuencias de correo que mantienen el contacto durante ciclos de venta largos. No se trata de publicar por publicar, sino de construir un activo que atrae clientes de forma constante. En Morphos cada pieza está atada a una intención — autoridad, posicionamiento o conversión — y se mide en resultados de negocio, no en métricas de vanidad.'
  },
  {
    q: '¿El marketing de contenidos funciona para empresas industriales B2B?',
    a: 'Sí, y a menudo mejor que en consumo. El comprador industrial investiga a fondo antes de cotizar: compara proveedores, lee, busca evidencia técnica. El contenido bien hecho es justo lo que consume en esa etapa — y la empresa que aparece con respuestas claras y autoridad técnica entra a la conversación con ventaja. Un caso de éxito, una guía sobre cómo elegir cierto equipo o un artículo que resuelve una duda técnica valen más que cualquier anuncio para ese comprador. Además, ese contenido alimenta tu SEO y tu LinkedIn al mismo tiempo. La clave es que sea contenido con criterio de industria, no genérico.'
  },
  {
    q: '¿Qué incluye el servicio de marketing de contenidos?',
    a: 'Cubrimos la cadena completa: estrategia de contenido (qué temas, para qué etapa del embudo y con qué objetivo), producción (artículos de blog optimizados para SEO, guías, casos y material descargable), distribución (LinkedIn orgánico y secuencias de correo de nurturing) y medición (qué contenido trae tráfico calificado y leads). Trabajamos con un enfoque de reutilización: una pieza central se adapta a varios canales para multiplicar su alcance sin multiplicar el costo. Todo conectado a tu estrategia general de marketing — el contenido no vive aislado, alimenta tu SEO y tu generación de demanda.'
  },
  {
    q: '¿Cuánto tarda el marketing de contenidos en dar resultados?',
    a: 'Es una inversión de mediano plazo, no un canal de respuesta inmediata. Los primeros efectos en tráfico y posicionamiento suelen verse entre los 3 y 6 meses, y el efecto compuesto — donde el contenido acumulado trae leads de forma constante — madura a partir de los 6 a 12 meses. La ventaja es que, a diferencia de la pauta, el contenido no deja de trabajar cuando dejas de invertir: un buen artículo sigue atrayendo clientes por años. Por eso lo tratamos como un activo. Si buscas leads para mañana, Google Ads es el canal; el contenido construye el motor que reduce tu dependencia de la pauta con el tiempo.'
  }
];
---
<Base
  title='Agencia de Marketing de Contenidos B2B | Morphos'
  description='Agencia de marketing de contenidos para empresas B2B e industriales. Contenido que genera demanda, autoridad y leads calificados — no views de vanidad. SEO, LinkedIn y nurturing en un solo sistema.'
  canonical='https://www.morphosagency.com/agencia-de-marketing-de-contenidos/'
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />

  <div class="page active" id="page-contenidos">

    <!-- Hero -->
    <section class="srv-hero">
      <div class="srv-hero-bg-num">C</div>
      <div class="wrap srv-hero-inner">
        <a class="page-back" href="/">← Inicio</a>
        <div class="srv-hero-content">
          <div class="f-label c-green" style="margin-bottom:20px;">Marketing de Contenidos · B2B</div>
          <h1 class="f-h1 c-white" style="overflow:hidden;">
            <span style="display:block; animation: lineUp 0.8s var(--ease) both;">Agencia de marketing</span>
            <span style="display:block; animation: lineUp 0.8s 0.12s var(--ease) both;">de contenidos.</span>
          </h1>
          <p class="f-body" style="color:rgba(255,255,255,0.45); margin-top:24px; max-width:540px; animation: fadeUp 0.8s 0.3s var(--ease) both;">Contenido que genera demanda y autoridad para empresas B2B e industriales. No publicamos por publicar: cada pieza atrae, educa o convierte a tu comprador — y se mide en leads, no en likes.</p>
          <div style="margin-top:36px; animation: fadeUp 0.8s 0.45s var(--ease) both;">
            <a href="/agenda/" class="btn btn-primary btn-lg">
              <span>Agenda una llamada</span>
              <span class="arrow">→</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Pilares -->
    <Pillars items={pillars} />

    <!-- Por qué contenido -->
    <section class="services" style="padding-top:100px; padding-bottom:90px;">
      <div class="wrap" style="max-width:820px;">
        <div class="f-label c-green reveal" style="margin-bottom:20px;">Por qué importa</div>
        <h2 class="f-h2 c-navy reveal" style="margin-bottom:32px;">Tu comprador investiga<br>antes de contactarte.</h2>
        <p class="f-body c-muted reveal" style="margin-bottom:24px;">En B2B industrial, la decisión no se toma con un anuncio. El comprador lee, compara, busca evidencia técnica y consulta a su equipo durante semanas o meses antes de levantar el teléfono. El contenido es exactamente lo que consume en esa etapa — y la empresa que aparece con respuestas claras y autoridad entra a la conversación con una ventaja que la publicidad sola no da.</p>
        <p class="f-body c-muted reveal reveal-delay-1" style="margin-bottom:24px;">La mayoría de las agencias hacen "contenido" como relleno: posts genéricos para llenar un calendario. Nosotros producimos contenido con criterio de industria — un caso real, una guía técnica, un artículo que resuelve una duda concreta de tu comprador — el tipo de contenido que <strong>construye confianza y posiciona</strong> al mismo tiempo.</p>
        <p class="f-body c-muted reveal reveal-delay-2">Y no vive aislado: cada pieza alimenta tu <a href="/agencia-de-seo-en-monterrey/" style="color:var(--green); text-decoration:underline;">posicionamiento SEO</a>, tu presencia en LinkedIn y tus secuencias de correo. Es el activo que compone: una vez creado, sigue trayendo clientes sin pagar por cada clic.</p>
      </div>
    </section>

    <!-- Qué incluye -->
    <section class="addons-catalog-section">
      <div class="wrap">
        <div class="addons-catalog-header reveal">
          <div>
            <div class="f-label c-green" style="margin-bottom:16px;">Qué incluye</div>
            <h2 class="f-h2" style="color:var(--white);">De la estrategia<br>a la distribución.</h2>
          </div>
          <p class="f-body c-muted" style="padding-top:8px;">No es solo escribir. Es un sistema completo de contenido conectado a tu generación de demanda.</p>
        </div>
        <div class="reveal reveal-delay-1">
          <Offerings items={ofrecemos} cols={2} />
        </div>
        <div class="reveal reveal-delay-2" style="text-align:center; margin-top:48px;">
          <a href="/metodologia/" class="btn btn-ghost">
            <span>Cómo se conecta con nuestra metodología 360</span>
            <span class="arrow">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-split-section">
      <div class="wrap">
        <div class="faq-split-grid">
          <div class="faq-split-left">
            <div class="faq-highlight reveal">
              <div class="faq-highlight-label">El criterio de fondo</div>
              <div class="faq-highlight-quote">El contenido no es para llenar un calendario. Es para <em>ganar la conversación</em> antes que tu competencia.</div>
              <div class="faq-highlight-sub">Cada pieza atrae, educa o convierte. Si no tiene un trabajo claro, no la publicamos.</div>
            </div>
          </div>
          <div class="faq-split-right">
            <div class="f-label c-green" style="margin-bottom:16px;">Preguntas frecuentes</div>
            <h2 class="f-h2 c-navy" style="margin-bottom:40px;">Marketing de contenidos,<br>sin relleno.</h2>
            <div class="faq-list">
              {faqs.map((f, i) => (
                <div class={`faq-item reveal${i % 3 === 1 ? ' reveal-delay-1' : i % 3 === 2 ? ' reveal-delay-2' : ''}`}>
                  <button class="faq-q" aria-expanded="false">
                    <span>{f.q}</span>
                    <span class="faq-icon">+</span>
                  </button>
                  <div class="faq-a">
                    <p>{f.a}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-final">
      <div class="wrap cta-final-inner">
        <div class="cta-tag reveal">Siguiente paso</div>
        <h2 class="reveal reveal-delay-1">¿Listo para que tu contenido<br><em>trabaje</em> por ti?</h2>
        <p class="reveal reveal-delay-2">Agenda 30 minutos con Omar. Revisamos qué contenido tiene más sentido para tu comprador y tu etapa — sin presentación de ventas, solo una respuesta honesta.</p>
        <div class="reveal reveal-delay-3">
          <a href="/agenda/" class="btn btn-primary btn-lg">
            <span>Agenda tu llamada gratuita</span>
            <span class="arrow">→</span>
          </a>
          <p class="cta-note">Sesión 1 a 1 con Omar · 30 minutos · Sin compromiso</p>
        </div>
      </div>
    </section>

  </div>
</Base>
