---
import Base from '../layouts/Base.astro';
import Pillars from '../components/Pillars.astro';
import Offerings from '../components/Offerings.astro';

const incluye = [
  { title: 'SEO técnico', desc: 'Velocidad y Core Web Vitals, indexación, schema markup, arquitectura de URLs y salud del sitio. La base sin la cual ningún contenido rankea.' },
  { title: 'Contenido y autoridad', desc: 'Páginas de servicio, blog temático y construcción de enlaces que dan a tu dominio la autoridad para competir. El factor que más pesa a largo plazo.' },
  { title: 'SEO local Monterrey', desc: 'Google Business Profile, consistencia de NAP y posicionamiento por zona. Para que aparezcas cuando buscan tu servicio cerca de ti.' },
];

const pillars = [
  { num: '01', title: 'Medido en leads, no en rankings vacíos', desc: 'No vendemos posiciones por vanidad. Posicionamos los términos que tu comprador busca con intención de compra.' },
  { num: '02', title: 'Especialistas en B2B industrial', desc: 'Conocemos cómo y qué busca el comprador técnico. SEO pensado para ciclos de venta largos, no para e-commerce.' },
  { num: '03', title: 'Técnico + contenido + IA', desc: 'SEO técnico, autoridad de contenido y AEO (ChatGPT, AI Overviews) en un solo sistema, no piezas sueltas.' },
  { num: '04', title: 'Monterrey y todo México', desc: 'Posicionamiento local para Monterrey y alcance nacional para empresas que venden en todo el país.' },
];

const faqs = [
  {
    q: '¿Cuánto tarda el SEO en dar resultados en Monterrey?',
    a: 'El SEO es un canal de mediano y largo plazo: los primeros movimientos de posiciones suelen verse entre los 2 y 4 meses, y los resultados sólidos en leads orgánicos entre los 6 y 12 meses. No es instantáneo como Google Ads, pero es el activo que compone: una vez que rankeas, atraes clientes sin pagar por cada clic. En términos locales de Monterrey la competencia está concentrada en pocos sitios con autoridad, así que ganamos primero por los flancos — términos industriales y de nicho menos disputados — mientras construimos la autoridad para pelear los términos más competidos. Si alguien te promete primer lugar en semanas, desconfía.'
  },
  {
    q: '¿Cuánto cuesta una agencia de SEO en Monterrey?',
    a: 'El SEO técnico en Morphos arranca desde $3,000–$5,000 MXN/mes como add-on, y el SEO en IA/AEO desde $4,000–$7,000 MXN/mes. El precio real depende del estado actual de tu sitio, la competencia de tus términos y el alcance (local vs nacional). A diferencia de la pauta, el SEO no tiene un costo de medios aparte: es trabajo de optimización y contenido. En la llamada inicial revisamos tu caso y te damos un número concreto — sin paquetes genéricos ni letra chica.'
  },
  {
    q: '¿Qué incluye el servicio de SEO?',
    a: 'Cubrimos las tres capas que mueven posiciones: SEO técnico (velocidad, Core Web Vitals, indexación, schema markup, arquitectura de URLs), SEO de contenido y autoridad (páginas de servicio, blog temático y enlaces que construyen tu reputación de dominio) y SEO local (Google Business Profile, consistencia de NAP, posicionamiento por zona de Monterrey). Además trabajamos AEO: optimización para aparecer en respuestas de IA como ChatGPT y los AI Overviews de Google — el canal orgánico que la mayoría de tu competencia aún no atiende. Todo medido en tráfico calificado y leads, no en métricas de vanidad.'
  },
  {
    q: '¿Qué conviene primero, SEO o Google Ads?',
    a: 'Depende de tu urgencia. Google Ads trae leads rápido — en semanas — pero dejas de aparecer en cuanto pausas la inversión. El SEO tarda más en madurar pero genera un activo que sigue trayendo clientes sin pagar por clic. La estrategia ideal en B2B industrial suele ser combinarlos: Google Ads para capturar demanda inmediata mientras el SEO compone en el fondo. En la llamada te decimos cuál tiene más sentido para tu etapa, presupuesto y competencia — no vendemos uno solo por defecto.'
  }
];
---
<Base
  title='Agencia de SEO en Monterrey · Posicionamiento Web B2B | Morphos'
  description='Agencia de SEO en Monterrey para empresas B2B e industriales. Posicionamiento web, SEO técnico y SEO en IA que traen leads calificados, no tráfico de vanidad. Sin microgestión.'
  canonical='https://www.morphosagency.com/agencia-de-seo-en-monterrey/'
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />

  <div class="page active" id="page-seo-mty">

    <!-- Hero -->
    <section class="srv-hero">
      <div class="srv-hero-bg-num">S</div>
      <div class="wrap srv-hero-inner">
        <a class="page-back" href="/">← Inicio</a>
        <div class="srv-hero-content">
          <div class="f-label c-green" style="margin-bottom:20px;">SEO · Monterrey · B2B</div>
          <h1 class="f-h1 c-white" style="overflow:hidden;">
            <span style="display:block; animation: lineUp 0.8s var(--ease) both;">Agencia de SEO</span>
            <span style="display:block; animation: lineUp 0.8s 0.12s var(--ease) both;">en Monterrey.</span>
          </h1>
          <p class="f-body" style="color:rgba(255,255,255,0.45); margin-top:24px; max-width:540px; animation: fadeUp 0.8s 0.3s var(--ease) both;">Posicionamiento web para empresas B2B e industriales en Monterrey y todo México. SEO que trae clientes con intención de compra — no tráfico de vanidad. El activo que compone: leads sin pagar por cada clic.</p>
          <div style="margin-top:36px; animation: fadeUp 0.8s 0.45s var(--ease) both;">
            <a href="/agenda/" class="btn btn-primary btn-lg">
              <span>Agenda una llamada</span>
              <span class="arrow">→</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Pilares -->
    <Pillars items={pillars} />

    <!-- Por qué SEO -->
    <section class="services" style="padding-top:100px; padding-bottom:90px;">
      <div class="wrap" style="max-width:820px;">
        <div class="f-label c-green reveal" style="margin-bottom:20px;">Por qué importa</div>
        <h2 class="f-h2 c-navy reveal" style="margin-bottom:32px;">El SEO es el único canal<br>que no deja de trabajar.</h2>
        <p class="f-body c-muted reveal" style="margin-bottom:24px;">Cuando pausas Google Ads, dejas de aparecer ese mismo día. El SEO es distinto: una vez que posicionas las páginas correctas, siguen atrayendo a quien busca lo que vendes — mes tras mes, sin pagar por cada clic. Para una empresa B2B industrial, donde el comprador investiga a fondo antes de cotizar, <strong>ser el que aparece cuando busca</strong> es una ventaja que compone con el tiempo.</p>
        <p class="f-body c-muted reveal reveal-delay-1" style="margin-bottom:24px;">La mayoría de las agencias venden "SEO" como rankear palabras genéricas que se ven bien en un reporte pero no traen negocio. Nosotros posicionamos los términos que tu comprador técnico realmente busca — los de alta intención — y medimos el resultado en <strong>tráfico calificado y leads</strong>, no en posiciones vacías.</p>
        <p class="f-body c-muted reveal reveal-delay-2">En Monterrey los términos más buscados los dominan pocos sitios con años de autoridad. Por eso nuestra estrategia empieza por los flancos — <a href="/agencia-de-marketing-industrial/" style="color:var(--green); text-decoration:underline;">términos industriales y de nicho</a> menos disputados donde sí puedes ganar — mientras construimos la autoridad para pelear los términos grandes a 6-12 meses. SEO con criterio, no a ciegas.</p>
      </div>
    </section>

    <!-- Qué incluye el SEO -->
    <section class="addons-catalog-section">
      <div class="wrap">
        <div class="addons-catalog-header reveal">
          <div>
            <div class="f-label c-green" style="margin-bottom:16px;">Qué incluye</div>
            <h2 class="f-h2" style="color:var(--white);">Las capas que mueven<br>posiciones de verdad.</h2>
          </div>
          <p class="f-body c-muted" style="padding-top:8px;">No es un solo truco. El posicionamiento real es la suma de tres frentes técnicos trabajados juntos.</p>
        </div>
        <div class="reveal reveal-delay-1">
          <Offerings items={incluye} cols={3} />
        </div>
        <div class="reveal reveal-delay-2" style="text-align:center; margin-top:48px;">
          <a href="/metodologia/" class="btn btn-ghost">
            <span>Cómo se conecta con nuestra metodología 360</span>
            <span class="arrow">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- AEO / GEO — el SEO de la era de la IA (diferenciador destacado) -->
    <section class="aeo-band">
      <div class="wrap aeo-inner">
        <div class="f-label c-green reveal" style="margin-bottom:18px;">Lo más trending en 2026</div>
        <h2 class="f-h2 c-white reveal" style="margin-bottom:24px;">AEO: aparece cuando tu<br>cliente le pregunta a la IA.</h2>
        <p class="f-body reveal reveal-delay-1" style="color:rgba(255,255,255,0.5); max-width:700px; margin-bottom:48px;">Cada vez más compradores le preguntan a ChatGPT, Perplexity o a los AI Overviews de Google en lugar de revisar diez enlaces. Si tu empresa no aparece en esas respuestas, no existe para ese cliente. El <strong style="color:#fff;">AEO (Answer Engine Optimization)</strong> y el <strong style="color:#fff;">GEO (Generative Engine Optimization)</strong> optimizan tu presencia para que los motores de IA te citen — y ya lo trabajamos como parte del servicio.</p>
        <div class="aeo-grid reveal reveal-delay-2">
          <div class="aeo-item">
            <div class="aeo-item-t">El comportamiento ya cambió</div>
            <div class="aeo-item-d">La búsqueda con IA es el canal de más rápido crecimiento. Tu comprador técnico ya la usa para investigar y comparar proveedores.</div>
          </div>
          <div class="aeo-item">
            <div class="aeo-item-t">Tu competencia aún no lo trabaja</div>
            <div class="aeo-item-d">La mayoría de las agencias en México todavía ignora el AEO. Es tu ventana para adelantarte mientras está abierta.</div>
          </div>
          <div class="aeo-item">
            <div class="aeo-item-t">Es SEO de calidad, sin trucos</div>
            <div class="aeo-item-d">No hay atajos: se gana con contenido claro, citable y autoridad real. Justo lo que ya construimos en cada proyecto.</div>
          </div>
        </div>
        <div class="reveal reveal-delay-3" style="margin-top:44px;">
          <a href="/agenda/" class="btn btn-primary btn-lg">
            <span>Quiero aparecer en las respuestas de IA</span>
            <span class="arrow">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-split-section">
      <div class="wrap">
        <div class="faq-split-grid">
          <div class="faq-split-left">
            <div class="faq-highlight reveal">
              <div class="faq-highlight-label">El criterio de fondo</div>
              <div class="faq-highlight-quote">El primer lugar no sirve de nada si nadie que <em>compra</em> está buscando ese término.</div>
              <div class="faq-highlight-sub">Posicionamos por intención de compra, no por volumen vacío. Tráfico que cotiza, no que infla el reporte.</div>
            </div>
          </div>
          <div class="faq-split-right">
            <div class="f-label c-green" style="margin-bottom:16px;">Preguntas frecuentes</div>
            <h2 class="f-h2 c-navy" style="margin-bottom:40px;">SEO en Monterrey,<br>sin humo.</h2>
            <div class="faq-list">
              {faqs.map((f, i) => (
                <div class={`faq-item reveal${i % 3 === 1 ? ' reveal-delay-1' : i % 3 === 2 ? ' reveal-delay-2' : ''}`}>
                  <button class="faq-q" aria-expanded="false">
                    <span>{f.q}</span>
                    <span class="faq-icon">+</span>
                  </button>
                  <div class="faq-a">
                    <p>{f.a}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-final">
      <div class="wrap cta-final-inner">
        <div class="cta-tag reveal">Siguiente paso</div>
        <h2 class="reveal reveal-delay-1">¿Listo para que te<br><em>encuentren</em> en Monterrey?</h2>
        <p class="reveal reveal-delay-2">Agenda 30 minutos con Omar. Revisamos el estado actual de tu sitio, dónde está tu oportunidad real de posicionamiento, y si Morphos es el socio correcto — sin presentación de ventas.</p>
        <div class="reveal reveal-delay-3">
          <a href="/agenda/" class="btn btn-primary btn-lg">
            <span>Agenda tu llamada gratuita</span>
            <span class="arrow">→</span>
          </a>
          <p class="cta-note">Sesión 1 a 1 con Omar · 30 minutos · Sin compromiso</p>
        </div>
      </div>
    </section>

  </div>

  <style>
    .aeo-band { background: var(--navy); padding: 110px 0; }
    .aeo-inner { max-width: 1000px; }
    .aeo-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; }
    .aeo-item { border-top: 2px solid rgba(122, 158, 126, 0.5); padding-top: 20px; }
    .aeo-item-t {
      font-family: 'Montserrat', sans-serif;
      font-weight: 700; font-size: 1.02rem;
      color: #fff; margin-bottom: 10px; line-height: 1.3;
    }
    .aeo-item-d { color: rgba(255, 255, 255, 0.45); font-size: 0.9rem; line-height: 1.6; }
    @media (max-width: 760px) {
      .aeo-band { padding: 72px 0; }
      .aeo-grid { grid-template-columns: 1fr; gap: 24px; }
    }
  </style>
</Base>
